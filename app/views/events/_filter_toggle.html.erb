<div class="bookmark_link">
  <span class="toggle-text-color">Bookmarked</span>

  <%= form_with url: events_path, method: :get, class: "toggle-form",
      data: { turbo_stream: true } do %>
    <%= hidden_field_tag :query, params[:query] %>

    <%# unchecked = All, checked = Bookmarked %>
    <%= check_box_tag :filter,
        "bookmarked",
        @filter == "bookmarked",
        id: "events_filter_toggle_input",
        class: "toggle-input",
        onchange: "this.form.requestSubmit()" %>

    <%= label_tag :events_filter_toggle_input, class: "toggle-switch" do %>
      <%# <span class="toggle-label toggle-label-all">All</span> %>
      <%# <span class="toggle-label toggle-label-bookmarked">Bookmarked</span> %>
      <span class="toggle-knob"></span>
    <% end %>
  <% end %>
</div>
