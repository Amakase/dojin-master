<div class="booths-grid-wrapper">
<div class="booths-results-bar">
  <span class="booths-results-count">
    <%= @booths.count %> <%= "booth".pluralize(@booths.count) %>
  </span>
   <%= form_with url: event_path(@event), method: :get, data: { turbo_frame: "_top" } do %>
    <%= hidden_field_tag :query, params[:query] %>
    <%= select_tag :filter_by,
          grouped_options_for_select(
            [
              ["Booth Space", [
                ["カタログ", "space:カタログ"],
                ["一展",     "space:一展"],
                ["二展",     "space:二展"]
              ]],
              ["My Collection", [
                ["Owned Works", "inventory"]
              ]],
              ["アニメ・ゲーム", [
                ["PC・ネットゲーム",       "［アニメ・ゲーム］PC・ネットゲーム"],
                ["VOCALOID",             "［アニメ・ゲーム］VOCALOID"],
                ["アニメソング",           "［アニメ・ゲーム］アニメソング"],
                ["コンシューマ・アーケード", "［アニメ・ゲーム］コンシューマ・アーケード"],
                ["レトロゲーム",           "［アニメ・ゲーム］レトロゲーム"],
                ["東方 Project",          "［アニメ・ゲーム］東方 Project"],
                ["音ゲー",               "［アニメ・ゲーム］音ゲー"]
              ]],
              ["マルチメディア", [
                ["YouTuber/VTuber",          "［マルチメディア］YouTuber/VTuber"],
                ["その他ノンジャンル",         "［マルチメディア］その他ノンジャンル"],
                ["ソフトウエア・ゲームソフト", "［マルチメディア］ソフトウエア・ゲームソフト"],
                ["ハードウエア・楽譜・書籍",   "［マルチメディア］ハードウエア・楽譜・書籍"]
              ]],
              ["映像", [
                ["アニメ（セル・CG 等）",    "［映像］アニメ（セル・CG 等）"],
                ["その他（実験映像等）",      "［映像］その他（実験映像等）"],
                ["静止画（2D・3D データ等）", "［映像］静止画（2D・3D データ等）"]
              ]],
              ["音楽", [
                ["クラシック・ジャズ・環境音楽等", "［音楽］クラシック・ジャズ・環境音楽等"],
                ["テクノ・クラブ",              "［音楽］テクノ・クラブ"],
                ["ポップス",                  "［音楽］ポップス"],
                ["ロック",                    "［音楽］ロック"]
              ]],
              ["音響", [
                ["その他",                      "［音響］その他"],
                ["ドラマ・トーク（放送劇・声優等）", "［音響］ドラマ・トーク（放送劇・声優等）"]
              ]]
            ],
            params[:filter_by]
          ),
          include_blank: "-- Filter --",
          class: "form-select form-select-sm bg-white rounded-5",
          style: "min-width: 200px;",
          aria: { label: "Filter booths" },
          onchange: "this.form.requestSubmit()" %>
  <% end %>
</div>
<div class="cards">
  <% @booths.each do |booth| %>
    <div class="card">
      <div class="card-body card-fixed-width">
        <%= link_to booth_path(booth.id), class: "text-decoration-none", data: { turbo_frame: "_top" } do %>
          <h5 class="card-title text-black text-center fw-bolder">
              <%= booth.circle.name %>
          </h5>
          <div class="position-relative">
            <%= render "shared/circle_cut", booth: booth, circle: booth.circle, width: 180, height: 256 %>
            <div class="booth-card-meta">
              <span class="booth-meta-chip"><i class="fa-solid fa-location-dot"></i> <%= booth.booth_space %></span>
              <% if @event.end_date - @event.start_date != 0 %>
                <span class="booth-meta-chip"><i class="fa-solid fa-calendar-day"></i> Day <%= (booth.booth_day - @event.start_date + 1).to_i %></span>
              <% end %>
            </div>
            <p class="booth-genre-tag"><i class="fa-solid fa-tag"></i> <%= booth.genre %></p>
            <small class="card-text text-muted d-block mt-1"><i class="fa-solid fa-comment-dots"></i> <%= truncate(booth.description, length: 30) %></small>
            <% if @notified_booth_ids.include?(booth.id) && @prioritized_booth_ids.include?(booth.id) %>
              <span class="badge rounded-5 position-absolute notification-adjust">
                <%= @notification_counts[booth.id] %>
              </span>
            <% else %>
              <span class="badge bg-danger rounded-5 position-absolute notification-adjust opacity-0">
              </span>
            <% end %>
          </div>
        <% end %>
        <div class="favorite-button-size">
          <%= turbo_frame_tag dom_id(booth, :favorite) do %>
            <%= render "shared/favorite_button", booth: booth, favorite: @favorites_by_booth_id[booth.id] %>
          <% end %>
        </div>
      </div>
    </div>
    <% end %>
</div>
</div>
