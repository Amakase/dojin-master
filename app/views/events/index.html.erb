<% content_for :head do %>
  <style>
    html, body { scrollbar-width: thin; }
    html::-webkit-scrollbar, body::-webkit-scrollbar { display: width: 6px; height: 6px; }
  </style>
<% end %>

<section class="events-index">
  <div class="events-index__header">
    <h1 class="event-page-title events-index__title">Event List</h1>

    <%= turbo_frame_tag "search_frame", class: "events-index__search" do %>
      <%= render "search_form" %>
    <% end %>
  </div>

  <%= render "filter_toggle" %>

  <%= turbo_frame_tag "events_frame" do %>
    <%= render "events_list" %>
  <% end %>
</section>
