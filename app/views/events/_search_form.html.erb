<div class="container events-index__breadcrumbs">
  <div class="pt-3">
    <%= render "shared/breadcrumbs", { event: nil, booth: nil } %>
  </div>
</div>

<div class="events-index__search-shell">
  <%= form_with url: events_path, method: :get, class: "event-search-form",
      data: { controller: "search", search_target: "form", action: "submit->search#prevent" } do %>
    <%= label_tag :query, "Search Events", class: "visually-hidden" %>
    <%= hidden_field_tag :filter, @filter %>
    <span class="event-search-form__icon" aria-hidden="true">
      <i class="fa-solid fa-magnifying-glass"></i>
    </span>
    <%= text_field_tag :query,
          params[:query],
          class: "form-control event-search-form__input",
          placeholder: "Search events, venue, date...",
          data: { search_target: "input", action: "input->search#search" } %>
    <%= submit_tag "Search", name: "", class: "btn btn-primary visually-hidden" %>
  <% end %>
</div>
