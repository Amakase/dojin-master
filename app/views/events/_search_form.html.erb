<div class="container">
  <div class="pt-3">
    <%= render "shared/breadcrumbs", { event: nil, booth: nil } %>
  </div>
</div>
<div class="event-show row justify-content-center">
  <div class="col-sm-8 my-3">
    <%= form_with url: events_path, method: :get, class: "d-flex event-search-form",
        data: { controller: "search", search_target: "form", action: "submit->search#prevent" } do %>
      <%= label_tag :query, "Search Events", class: "visually-hidden" %>
      <%= hidden_field_tag :filter, @filter %>
      <%= text_field_tag :query,
            params[:query],
            class: "form-control bg-white",
            placeholder: "Type a keyword",
            data: { search_target: "input", action: "input->search#search" } %>
      <%= submit_tag "Search", name: "", class: "btn btn-primary visually-hidden" %>
    <% end %>
  </div>
</div>
