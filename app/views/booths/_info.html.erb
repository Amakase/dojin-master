<div class="d-flex justify-content-between align-items-center">
  <div>
    <div class="fs-1">
      <span class="fw-bold">Circle: </span>
      <%= booth.circle.name %>
    </div>
    <div>
      <h2>
        <strong>Event:</strong> <%= event.name %>
      </h2>
    </div>
  </div>
  <div>
    <%= turbo_frame_tag dom_id(@booth, :favorite) do %>
      <%= render "shared/favorite_button", booth: booth %>
    <% end %>
  </div>
</div>
<div class="d-flex my-3 justify-content-between">
  <div>
    <strong>Day: </strong> <%= booth.booth_day %>,
    <strong>Booth: </strong> <%= booth.booth_space %>
  </div>
  <div>
    <strong>Section: </strong> <%= booth.genre %>
  </div>
</div>
<div>
  <strong>Description: </strong> <%= booth.description %>
</div>
