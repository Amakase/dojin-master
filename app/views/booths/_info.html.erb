<div class="d-flex justify-content-between align-items-center">
  <div>
    <div class="fs-1">
      <span class="fw-bold">Circle: </span>
      <%= booth.circle.name %>
    </div>
      <div class="fs-2">
        <span class="fw-bold">Event:</span>
        <%= event.name %>
      </div>
  </div>
  <div>
    <% if booth.favorites.find_by(user:current_user) %>
      <%= link_to favorite_path(booth.favorites.find_by(user:current_user)),
                  data: { turbo_method: :patch } do %>
        <div class="btn border">
          Priority: <%= booth.favorites.find_by(user:current_user).priority %>
        </div>
      <% end %>
    <% else %>
      <%= link_to booth_favorites_path(booth),
                        data: { turbo_method: :post } do %>
        <div class="btn border">
          No Priority
        </div>
      <% end %>
    <% end %>
  </div>
</div>
<div class="d-flex justify-content-between">
  <div>
    <strong>Day: </strong> <%= booth.booth_day %>,
    <strong>Booth: </strong> <%= booth.booth_space %>
  </div>
  <div>
    <strong>Section: </strong> <%= booth.genre %>
  </div>
</div>
<div>
  <strong>Description: </strong> <%= booth.description %>
</div>
