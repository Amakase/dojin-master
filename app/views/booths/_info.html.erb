<div class="col-12">
  <div class="booth-info-card">
    <div class="row g-0 align-items-stretch">

      <%# Circle-cut image %>
      <div class="col-auto d-flex align-items-center p-3">
        <% if booth.image.attached? %>
          <%= image_tag booth.image,
                class: "booth-circle-image",
                alt: "Booth Circle-Cut Image" %>
        <% elsif circle.image.attached? %>
          <%= image_tag circle.image,
                class: "booth-circle-image",
                alt: "Circle Image" %>
        <% else %>
          <%= image_tag "blank_circle_cut.png",
                class: "booth-circle-image",
                alt: "Default Image" %>
        <% end %>
      </div>

      <%# Main info %>
      <div class="col d-flex flex-column justify-content-center p-3 p-md-4">
        <h1 class="booth-circle-name mb-2"><%= circle.name %></h1>

        <div class="d-flex flex-wrap gap-2 mb-3">
          <% if !booth.event.single_day? %>
          <span class="booth-badge">
            <i class="fa-solid fa-calendar-day me-1"></i>Day <%= booth.day_number %>
          </span>
          <% end %>
          <span class="booth-badge">
            <i class="fa-solid fa-location-dot me-1"></i><%= booth.booth_space %>
          </span>
          <% if booth.genre.present? %>
            <span class="booth-badge">
              <i class="fa-solid fa-tag me-1"></i><%= booth.genre %>
            </span>
          <% end %>
        </div>

        <% if booth.description.present? %>
          <p class="booth-description mb-0"><%= booth.description %></p>
        <% end %>
      </div>

      <%# Favorite button %>
      <div class="col-12 col-md-auto d-flex flex-column align-items-center justify-content-center p-3 booth-info-sidebar">
        <p class="booth-notes mb-2">Your Priority</p>
        <%= turbo_frame_tag dom_id(booth, :favorite) do %>
          <%= render "shared/favorite_button", booth: booth, favorite: favorite, button_class: "text-white" %>
        <% end %>
      </div>

    </div>
  </div>
</div>
