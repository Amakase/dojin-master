<% if booth_works.any? %>
  <div class="row g-3">
    <% booth_works.each do |booth_work| %>
      <div class="col-sm-6 col-lg-4">
        <div class="booth-panel-card h-100">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="fw-bold mb-0 me-2"><%= booth_work.title %> <% if booth_work.limit.present? %>
              (<span class="text-danger">Limit: <%= booth_work.limit %></span>)
            <% end %></h6>
            <% if booth_work.new_release %>
              <span class="badge bg-danger flex-shrink-0">New</span>
            <% end %>
          </div>
          <p class="mb-1">
            <span class="fw-semibold booth-meta-text"><i class="fa-solid fa-basket-shopping me-1"></i>Get: <%= booth_work.num_to_buy %></span>
          </p>
          <% if booth_work.price.present? %>
            <p class="mb-0 booth-meta-text">
              <i class="fa-solid fa-yen-sign me-1"></i><%= number_with_delimiter(booth_work.price) %>
            </p>
          <% end %>
          <% if booth_work.notes.present? %>
            <p class="mb-0 booth-meta-text">
              <i class="fa-solid fa-pencil me-1"></i><%= booth_work.notes %>
            </p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="booth-empty-state">
    <i class="fa-regular fa-folder-open fa-2x mb-3"></i>
    <p class="mb-0">No works listed for this booth.</p>
  </div>
<% end %>
