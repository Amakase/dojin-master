<%= turbo_stream_from "ai_placement_#{@event.id}" %>
<div class="container-fluid py-3 map-editor-page"
     data-controller="map-editor"
     data-map-editor-coords-value="<%= @existing_coords.to_json %>"
     data-map-editor-booth-spaces-value="<%= @booth_spaces.to_json %>"
     data-map-editor-save-url-value="<%= admin_event_map_editor_path(@event) %>"
     data-map-editor-image-url-value="<%= @event.floor_plan.attached? ? url_for(@event.floor_plan) : '' %>"
     data-map-editor-walls-value="<%= (@event.wall_rects || []).to_json %>">

  <%# Header %>
  <div class="d-flex align-items-center justify-content-between me-header">
    <div>
      <p class="me-header__label mb-0">Map Editor</p>
      <h4 class="me-header__title"><%= @event.name %></h4>
    </div>
    <div class="d-flex align-items-center gap-3">
      <span data-map-editor-status class="me-status"></span>
      <% if @event.floor_plan.attached? %>
        <div class="me-ai-cluster">
          <%= button_to admin_event_ai_placement_path(@event),
                method: :post,
                class: "btn btn-me-ai",
                disabled: @event.ai_placement_status.in?(%w[pending running]) do %>
            <i class="fa-solid fa-wand-magic-sparkles btn-me-ai__icon"></i>
            AI Auto-place
          <% end %>
          <%= render "admin/map_editors/ai_placement_status",
                status: @event.ai_placement_status || "",
                message: ai_status_message(@event) %>
          <%# Section placement panel — pure geometry, no LLM call %>
          <div class="me-section-panel">
            <div class="me-section-panel__fields">
              <select class="me-section-panel__select me-section-panel__select--section"
                      data-map-editor-target="sectionSelect"
                      data-action="change->map-editor#onSectionChange">
                <option value="">Section…</option>
              </select>
              <select class="me-section-panel__select me-section-panel__select--anchor"
                      data-map-editor-target="sectionAnchor">
                <option value="">Anchor…</option>
              </select>
              <input type="number" min="1" placeholder="From"
                     class="me-section-panel__num"
                     data-map-editor-target="sectionRangeStart">
              <span class="me-section-panel__sep">–</span>
              <input type="number" min="1" placeholder="To"
                     class="me-section-panel__num"
                     data-map-editor-target="sectionRangeEnd">
              <div class="me-section-panel__layout">
                <button type="button"
                        data-layout="side-by-side"
                        class="me-section-panel__layout-btn me-section-panel__layout-btn--active"
                        data-action="click->map-editor#setSectionLayout"
                        title="Side-by-side (a/b horizontal)">↔</button>
                <button type="button"
                        data-layout="stacked-ttb"
                        class="me-section-panel__layout-btn"
                        data-action="click->map-editor#setSectionLayout"
                        title="Stacked top-to-bottom (ascending)">⬇</button>
                <button type="button"
                        data-layout="stacked-btt"
                        class="me-section-panel__layout-btn"
                        data-action="click->map-editor#setSectionLayout"
                        title="Stacked bottom-to-top (descending)">⬆</button>
              </div>
              <button type="button"
                      class="btn btn-me-ai btn-me-ai--sm"
                      data-action="click->map-editor#drawSectionArea"
                      data-map-editor-target="sectionDrawBtn">
                <i class="fa-solid fa-crosshairs btn-me-ai__icon"></i>
                Draw Section
              </button>
            </div>
            <span data-map-editor-target="sectionStatus"
                  class="me-section-panel__status"></span>
          </div>
        </div>
      <% end %>
      <button class="btn btn-me-save" data-action="click->map-editor#save">Save All</button>
    </div>
  </div>

  <div class="d-flex gap-3 align-items-start">
    <%# Sidebar %>
    <div class="me-sidebar">
      <div class="me-sidebar__inner">
        <h6 class="me-sidebar__title">Booth Spaces</h6>
        <p class="me-sidebar__counter" data-map-editor-counter>Placed: 0 / <%= @booth_spaces.size %></p>
        <div style="max-height: calc(100vh - 280px); overflow-y: auto;">
          <ul class="me-sidebar__list" data-map-editor-sidebar></ul>
        </div>
      </div>
    </div>

    <%# Canvas area %>
    <div class="flex-grow-1">
      <div class="me-toolbar">
        <button class="btn-me-add" data-action="click->map-editor#addRect">+ Add Rect</button>
        <button class="btn-me-wall" data-action="click->map-editor#drawWall">+ Draw Wall</button>
        <button class="btn-me-delete" data-action="click->map-editor#deleteSelected">Delete Selected</button>
        <button class="btn-me-reset" data-action="click->map-editor#resetZoom">Reset Zoom</button>
        <span class="me-toolbar__hint">Scroll or pinch to zoom · Alt + drag to pan</span>
      </div>
      <% if @event.floor_plan.attached? %>
        <div class="me-canvas-wrap">
          <canvas></canvas>
        </div>
      <% else %>
        <div class="alert alert-warning">No floor plan uploaded for this event yet.</div>
      <% end %>
    </div>
  </div>


</div>
