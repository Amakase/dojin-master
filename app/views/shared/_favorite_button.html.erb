<% favorite = local_assigns.fetch(:favorite) { current_user.favorites.find_by(booth: booth) } %>
<% base_state_class = favorite ? "fav-btn--active priority-btn-#{favorite.priority}" : "fav-btn--idle" %>
<% button_classes = ["btn", "fav-btn", base_state_class, local_assigns[:button_class]].compact.join(" ") %>

<div class="dropdown fav-dropdown">
  <button class="<%= button_classes %>"
          type="button"
          data-bs-toggle="dropdown"
          aria-expanded="false"
          aria-label="<%= favorite ? "Priority #{favorite.priority} — change" : "Add to favorites" %>">

    <% if favorite.present? %>
      <i class="fa-solid fa-heart fav-btn__icon" aria-hidden="true"></i>
      <span class="favorite-priority-span">Priority </span><span class="fav-btn__num"><%= favorite.priority %></span>
      <i class="fa-solid fa-chevron-down fav-btn__chevron" aria-hidden="true"></i>
    <% else %>
      <i class="fa-regular fa-heart fav-btn__icon" aria-hidden="true"></i>
      <span class="fav-btn__label">Favorite</span>
      <i class="fa-solid fa-chevron-down fav-btn__chevron" aria-hidden="true"></i>
    <% end %>

  </button>

  <ul class="dropdown-menu fav-dropdown__menu p-0" aria-label="Select priority">
    <li class="fav-dropdown__header">
      <span>Set priority</span>
      <span class="fav-dropdown__hint">1 = highest</span>
    </li>
    <div class="fav-dropdown__grid">
      <% (1..9).each do |level| %>
        <div class="fav-dropdown__cell">
          <% if favorite.present? %>
            <%= link_to favorite_path(favorite, favorite: { priority: level }),
                        data: { turbo_method: :patch },
                        class: "fav-dropdown__item priority-item priority-#{level} dropdown-priority-#{level} #{"fav-dropdown__item--current" if favorite.priority == level}",
                        aria: { label: "Priority #{level}" } do %>
              <%= level %>
            <% end %>
          <% else %>
            <%= link_to booth_favorites_path(booth, favorite: { priority: level }),
                        data: { turbo_method: :post },
                        class: "fav-dropdown__item priority-item priority-#{level} dropdown-priority-#{level}",
                        aria: { label: "Priority #{level}" } do %>
              <%= level %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </ul>
</div>
