<%# Required Arguments: booth, circle, width and height %>

<% if booth.image.attached? %>
  <%= image_tag booth.image,
        class: "circle-cut-img object-fit-contain border",
        alt: "Booth Circle-Cut Image",
        width: width,
        height: height,
        loading: "lazy" %>
<% elsif circle.image.attached? %>
  <%= image_tag circle.image,
        class: "circle-cut-img object-fit-contain border",
        alt: "Circle Image",
        width: width,
        height: height,
        loading: "lazy" %>
<% else %>
  <%= image_tag "blank_circle_cut.png",
        class: "circle-cut-img object-fit-contain border",
        alt: "Default Image",
        width: width,
        height: height,
        loading: "lazy" %>
<% end %>
