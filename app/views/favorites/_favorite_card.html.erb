<% booth = favorite.booth %>
<% circle = favorite.booth.circle %>

<div class="favorite-card-category d-flex justify-content-between align-items-center mb-2">
  <div class="favorite-circle-details me-1">
  <%= image_tag image_path("default_circle.jpg"), alt: "circle_image", class: "favorite-circle-image object-fit-cover border rounded" %>
<%# image_path(circle.image_filename.presence || "default_circle.jpg") %>

<%# url(<%= image_path(circle.image_filename.presence || "default_circle.jpg")  %>

    <%= link_to circle.name,
                booth_path(booth),
                class: "text-decoration-none text-white" %>
  </div>

  <div class="favorite-booth-details me-1">
    <div class="favorite-booth-day">Day: <%= booth.booth_day %></div>
    <div class="favorite-booth-space">Booth: <%= booth.booth_space %></div>
  </div>
    <div class="d-flex align-items-center">
      <%= simple_form_for favorite, html: { class: "favorite-notes-form d-flex me-1" } do |f| %>
        <%= f.input :notes,
          as: :text,
          label: false,
          wrapper: false,
          input_html: { class: "favorite-notes-input" } %>

        <%= f.button :submit, "Submit", class: "favorite-notes-btn p-0 ms-2 me-4" %>
      <% end %>
    </div>
  <%= turbo_frame_tag dom_id(booth, :favorite) do %>
    <%= render "shared/favorite_button", booth: booth %>
  <% end %>
  <i class="fa-solid fa-trash favorite-delete-btn"></i>

</div>
