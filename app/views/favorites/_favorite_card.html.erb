<% booth = favorite.booth %>
<% circle = favorite.booth.circle %>

<%# <div class="favorite-card-category d-flex justify-content-between align-items-center mb-2 rounded-5"> %>
<div class="favorite-card-category d-flex justify-content-start align-items-center mb-2 rounded-5">
    <%= turbo_frame_tag dom_id(booth, :favorite) do %>
      <%= render "shared/favorite_button", booth: booth %>
    <% end %>

  <div class="favorite-circle-details d-flex align-items-center ms-2 me-1 position-relative col-5 col-lg-5">
    <% if booth.image.attached? %>
      <%= link_to booth_path(booth) do %>
        <%= image_tag booth.image,
              id: "circle-image",
              alt: "Booth Circle-Cut Image",
              class: "favorite-circle-image object-fit-cover border rounded"
            %>
      <% end %>
    <% elsif circle.image.attached? %>
      <%= link_to booth_path(booth) do %>
        <%= image_tag circle.image,
              id: "circle-image",
              alt: "Circle Image",
              class: "favorite-circle-image object-fit-cover border rounded"
            %>
      <% end %>
    <% else %>
      <%= link_to booth_path(booth) do %>
        <%= image_tag "blank_circle_cut.png",
              id: "circle-image",
              alt: "Default Image",
              class: "favorite-circle-image object-fit-cover border rounded"
            %>
      <% end %>
    <% end %>

    <%
    user_favorites = booth.favorites.where(user: current_user)
    prioritized = user_favorites.where.not(priority: nil).exists?
    if booth.notifications.where(read: false).exists? && prioritized
    %>
      <span class="badge rounded-5 notification-adjust"><%= booth.notifications.select {|notification| !notification.read }.count %>
      </span>
    <% end %>

    <div class="favorite-booth-details ms-1 me-1">
      <%= link_to circle.name,
                booth_path(booth),
                class: "favorite-circle-name text-decoration-none text-wrap"
              %>
      <div class="booth-space-and-day d-flex">
        <div class="favorite-booth-space me-1"><i class="fa-solid fa-location-dot me-1"></i><%= booth.booth_space %></div>
        <% if booth.event.single_day? == false %>
          <div class="favorite-booth-day"><i class="fa-solid fa-calendar-day me-1"></i>Day <%= booth.day_number %></div>
        <% end %>
      </div>
      <div class="booth-genre"><i class="fa-solid fa-tag me-1"></i><%= booth.genre %></div>
    </div>
  </div>

  <div class="d-flex align-items-center col-3 col-lg-4">
    <%= simple_form_for favorite, html: { class: "favorite-notes-form d-flex mx-2 align-items-end", data: { controller: "notes" } } do |f| %>
      <%= f.input :notes,
        as: :text,
        label: false,
        wrapper: false,
        input_html: {
          id: dom_id(favorite, :notes),
          class: "favorite-notes-input",
          data: { action: "input->notes#autoSaveType blur->notes#autoSaveBlur",
                  notes_target: "input" },
          "data-turbo-permanent": true }
        %>
    <% end %>
  </div>
  <div class="form-check d-flex flex-column justify-content-center col-auto p-0">
    <p class="form-check-label ms-2 mb-0">Visited</p>
    <%= simple_form_for favorite, html: { class: "col-2 p-0" } do |f| %>
      <%= f.input :visited,
      as: :boolean,
      label: false,
      wrapper: false,
      input_html: {
        id: dom_id(favorite, :visited),
        class: "ms-1",
        onchange: "this.form.requestSubmit(); setTimeout(() => location.reload(), 300);",
        autocomplete: "off",
      } %>
    <% end %>
  </div>
  <%# <i class="fa-solid fa-trash favorite-delete-btn me-2"></i> %>

</div>
