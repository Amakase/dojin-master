<%# the dom_id is inserted 2 otherwise it would not persist after the 2nd update %>

<%= turbo_stream.replace dom_id(@booth, :favorite) do %>
  <%= turbo_frame_tag dom_id(@booth, :favorite) do %>
    <%= render "shared/favorite_button", booth: @booth %>
  <% end %>
<% end %>

<%= turbo_stream.append "body" do %>
  <script>setTimeout(() => Turbo.visit(window.location.href, { action: "replace" }), 100)</script>
<% end %>
