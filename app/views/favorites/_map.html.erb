<%# Renders the event floor plan with favorited booths highlighted in their priority color.
    Include this partial from favorites/index.html.erb once the teammate's branch is merged. %>
<%= render "shared/event_map",
      event: @event,
      booth_space_priorities: @favorites.each_with_object({}) { |f, h| h[f.booth.booth_space] = f.priority } %>
