<div class="container d-flex justify-content-center">
  <div class="justify-content-center row">
    <div class="pt-3">
      <%= render "shared/breadcrumbs", { event: @event, booth: @booth } %>
    </div>
    <%= render "shared/event_header", event: @event %>

    <div class="favorites-map-container">
      <%# <%= render "favorites/map", event: @event %>
    </div>

    <div class="favorite-cards-container d-flex justify-content-center col-12 col-lg-6 row">
      <div class="favorite-hint-map-btn">
        <p class="priority-hint">↑ lower number is higher priority</p>
        <%# <%= link_to , %>
      </div>
      <% @favorites.each do |favorite| %>
        <%= render 'favorite_card', favorite: favorite %>
      <% end %>
    </div>
  </div>
</div>
