<div class="container mt-3">
  <div class="row justify-content-center">
    <div class="d-flex justify-content-between">
      <h1 class="text-white text-center w-100"> <%= @event.name %> - Favorites</h1>
    </div>

    <div class="favorite-cards-container col-auto">
      <% @favorites.each do |favorite| %>
        <%= render 'favorite_card', favorite: favorite %>
      <% end %>
    </div>
  </div>
</div>
